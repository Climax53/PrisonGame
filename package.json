{
  "name": "wardens-keep",
  "version": "0.1.0",
  "private": true,
  "description": "Warden's Keep — a medieval jail-management mobile game.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "verify": "node scripts/verify.mjs",
    "check": "npm run typecheck && npm run test && npm run verify",
    "cap:sync": "cap sync"
  },
  "dependencies": {
    "@capacitor/preferences": "^6.0.4",
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.2.1",
    "playwright": "^1.61.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
